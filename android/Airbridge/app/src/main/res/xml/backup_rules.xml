<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 11 and below counterpart to data_extraction_rules.xml. Backup is already
    disabled via android:allowBackup="false"; this makes the intent explicit by excluding
    all app data (TLS identity, paired devices) from auto backup.
-->
<full-backup-content>
    <exclude domain="root" path="." />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
