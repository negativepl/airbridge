<?xml version="1.0" encoding="utf-8"?>
<!--
    AirBridge stores sensitive material on-device (the TLS identity and the list of
    paired devices). None of it should leave the device, so both cloud backup and
    device-to-device transfer exclude all app data. This is the Android 12+ counterpart
    to android:allowBackup="false" (which still governs Android 11 and below).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
