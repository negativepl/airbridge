<resources>
    <string name="app_name">AirBridge</string>
    <string name="accessibility_description">AirBridge uses this permission to read clipboard changes in the background and sync them with your Mac. No other data is accessed.</string>

    <!-- Onboarding -->
    <string name="onboarding_welcome_title">AirBridge</string>
    <string name="onboarding_welcome_desc">Your phone and Mac, finally on the same team.</string>
    <string name="onboarding_feature_clipboard">Sync the clipboard between your phone and Mac</string>
    <string name="onboarding_feature_files">Browse and transfer files and photos — no cloud</string>
    <string name="onboarding_feature_notifications">Your phone notifications on your Mac</string>
    <string name="onboarding_feature_more">…and much more</string>
    <string name="onboarding_feature_local">Private — your data never leaves your home network</string>
    <string name="onboarding_connect_title">How it works</string>
    <string name="onboarding_connect_desc">A few things worth knowing:</string>
    <string name="onboarding_how_wifi">Your phone and Mac must be on the same Wi-Fi network</string>
    <string name="onboarding_how_auto">Your Mac is found automatically — no IP addresses, no setup</string>
    <string name="onboarding_how_local">No internet needed — everything runs over your local network</string>
    <string name="onboarding_how_privacy">Your data never leaves home — nothing goes to the cloud</string>
    <string name="onboarding_how_pairing">Pair once with a QR code — after that it connects on its own</string>
    <string name="onboarding_ready_title">You\'re all set!</string>
    <string name="onboarding_ready_desc">Select any text in any app — a menu will appear with \'Send to Mac\' option. Tap it to transfer instantly.</string>
    <string name="onboarding_permissions_title">Permissions</string>
    <string name="onboarding_permissions_desc">AirBridge needs a few permissions to fully work.</string>
    <string name="onboarding_perm_notifications">Notifications — to show transfer progress</string>
    <string name="onboarding_perm_nearby">Local network — to find your Mac nearby</string>
    <string name="onboarding_perm_allow">Allow notifications</string>
    <string name="onboarding_perm_granted">Permissions granted</string>
    <string name="onboarding_perm_notifications_desc">Notifications</string>
    <string name="onboarding_perm_notifications_why">To show file transfer progress and incoming file requests from your Mac</string>
    <string name="onboarding_perm_sms_desc">SMS messages</string>
    <string name="onboarding_perm_sms_why">To browse and send SMS from your Mac. Messages stay on your phone — nothing is uploaded</string>
    <string name="onboarding_perm_photos_desc">Photo gallery</string>
    <string name="onboarding_perm_photos_why">To browse and download photos from your Mac. Photos are sent directly over your local network</string>
    <string name="onboarding_perm_contacts_desc">Contacts</string>
    <string name="onboarding_perm_contacts_why">To show contact names instead of phone numbers in the SMS view</string>
    <string name="onboarding_perm_files_desc">Files</string>
    <string name="onboarding_perm_files_why">To browse and transfer files from your Mac. Files are sent directly over your local network — nothing is uploaded to the cloud</string>
    <string name="onboarding_perm_overlay_desc">Display over other apps</string>
    <string name="onboarding_perm_overlay_why">So screen mirroring can start when you request it from your Mac, even while the app is in the background. Without it you have to open the app first</string>
    <string name="onboarding_perm_notiflistener_desc">Notifications on your Mac</string>
    <string name="onboarding_perm_notiflistener_why">So your phone notifications appear natively on your Mac. You choose which apps to show in the Mac settings</string>
    <string name="onboarding_perm_accessibility_desc">Control from your Mac</string>
    <string name="onboarding_perm_accessibility_why">So you can control your phone from your Mac when mirroring (taps, typing). Optional — only needed for remote control</string>
    <string name="onboarding_perm_optional_header">Optional — mirroring &amp; Mac notifications</string>
    <string name="onboarding_feature_mirror">Mirror your phone screen on your Mac — and back</string>
    <string name="onboarding_perm_allow_btn">Allow</string>
    <string name="onboarding_perm_all_granted">All permissions granted</string>
