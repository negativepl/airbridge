    <string name="app_name">Airbridge</string>
    <string name="accessibility_description">Airbridge używa tego uprawnienia, by odczytywać zmiany w schowku w tle i synchronizować je z komputerem Mac. Żadne inne dane nie są pobierane.</string>

    <!-- Onboarding -->
    <string name="onboarding_welcome_title">Airbridge</string>
    <string name="onboarding_welcome_desc">Twój telefon i komputer Mac, połączone jak nigdy dotąd.</string>
    <string name="onboarding_feature_clipboard">Synchronizuj schowek między telefonem, a komputerem Mac</string>
    <string name="onboarding_feature_files">Przesyłaj zdjęcia i pliki bezprzewodowo, bez chmury</string>
    <string name="onboarding_feature_local">Wszystko zostaje w Twojej sieci — pełna prywatność</string>
