<resources>
    <string name="app_name">AirBridge</string>

    <!-- Onboarding -->
    <string name="onboarding_welcome_title">AirBridge</string>
    <string name="onboarding_welcome_desc">Twój telefon i komputer Mac, połączone jak nigdy dotąd.</string>
    <string name="onboarding_feature_clipboard">Synchronizuj schowek między telefonem, a Makiem</string>
    <string name="onboarding_feature_files">Przeglądaj i przesyłaj pliki oraz zdjęcia, bez chmury</string>
    <string name="onboarding_feature_notifications">Powiadomienia z telefonu na Macu</string>
    <string name="onboarding_feature_more">…i wiele więcej</string>
    <string name="onboarding_connect_title">Jak to działa?</string>
    <string name="onboarding_connect_desc">Kilka rzeczy, które warto wiedzieć:</string>
    <string name="onboarding_how_wifi">Telefon i Mac muszą być w tej samej sieci Wi-Fi</string>
    <string name="onboarding_how_auto">Mac zostaje wykryty automatycznie — bez adresów IP i konfiguracji</string>
    <string name="onboarding_how_local">Nie potrzebujesz internetu — wszystko działa w Twojej sieci lokalnej</string>
    <string name="onboarding_how_privacy">Twoje dane nie opuszczają domu — nic nie trafia do chmury</string>
    <string name="onboarding_how_pairing">Parujesz raz kodem QR — potem łączy się samo</string>
    <string name="onboarding_permissions_title">Uprawnienia</string>
    <string name="onboarding_permissions_desc">AirBridge potrzebuje kilku uprawnień, aby działać w pełni prawidłowo.</string>
    <string name="onboarding_perm_notifications_desc">Powiadomienia</string>
    <string name="onboarding_perm_notifications_why">Aby pokazywać postęp przesyłania plików i prośby o odbiór plików z komputera Mac</string>
    <string name="onboarding_perm_sms_desc">Wiadomości SMS</string>
    <string name="onboarding_perm_sms_why">Aby przeglądać i wysyłać SMS z komputera Mac. Wiadomości zostają na telefonie — nic nie jest wysyłane do chmury</string>
    <string name="onboarding_perm_photos_desc">Galeria zdjęć</string>
    <string name="onboarding_perm_photos_why">Aby przeglądać i pobierać zdjęcia z komputera Mac. Zdjęcia przesyłane są bezpośrednio przez sieć lokalną</string>
    <string name="onboarding_perm_contacts_desc">Kontakty</string>
    <string name="onboarding_perm_contacts_why">Aby wyświetlać nazwy kontaktów zamiast numerów telefonów w widoku SMS</string>
    <string name="onboarding_perm_files_desc">Pliki</string>
    <string name="onboarding_perm_files_why">Aby przeglądać i przesyłać pliki telefonu z komputera Mac. Pliki przesyłane są bezpośrednio przez sieć lokalną — nic nie trafia do chmury</string>
    <string name="onboarding_perm_overlay_desc">Wyświetlanie nad aplikacjami</string>
    <string name="onboarding_perm_overlay_why">Aby mirror ekranu mógł wystartować zdalnie z Maca, nawet gdy aplikacja jest w tle. Bez tego trzeba najpierw otworzyć aplikację</string>
    <string name="onboarding_perm_notiflistener_desc">Powiadomienia na Macu</string>
    <string name="onboarding_perm_notiflistener_why">Aby powiadomienia z telefonu pojawiały się natywnie na Macu. Wybierzesz w ustawieniach Maca, które aplikacje pokazywać</string>
    <string name="onboarding_perm_accessibility_desc">Sterowanie z Maca</string>
    <string name="onboarding_perm_accessibility_why">Aby sterować telefonem z Maca podczas mirrora (dotyk, pisanie). Opcjonalne — tylko do zdalnego sterowania</string>
    <string name="onboarding_perm_optional_header">Dodatkowe — mirror i powiadomienia na Macu</string>
    <string name="onboarding_feature_mirror">Pokaż ekran telefonu na Macu — i odwrotnie</string>
    <string name="onboarding_perm_allow_btn">Zezwól</string>
    <string name="onboarding_perm_granted_short">Przyznano</string>
    <string name="onboarding_perm_all_granted">Wszystkie uprawnienia nadane</string>
    <string name="onboarding_next">Dalej</string>

